<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Manage Blogs | <%= siteName %></title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">
  <link rel="icon" type="image/png" href="/images/logo.png">
  <style>
    body { background: #f4f6f8; }
    .sidebar-admin { width: 220px; min-height: 100vh; position: fixed; top: 0; left: 0; background: #1e2a38; z-index: 100; }
    .main-content  { margin-left: 220px; }
    .sidebar-admin .nav-link { color: #adb5bd; }
    .sidebar-admin .nav-link:hover, .sidebar-admin .nav-link.active { color: #fff; background: rgba(255,193,7,.15); border-radius: 6px; }
  </style>
</head>
<body>
  <nav class="sidebar-admin p-3 d-flex flex-column">
    <div class="mb-4 mt-2 text-center">
      <img src="/images/logo.png" alt="<%= siteName %>" style="height:40px;width:auto;object-fit:contain;filter:brightness(0) invert(1);">
    </div>
    <ul class="nav flex-column gap-1 flex-grow-1">
      <li><a href="/admin" class="nav-link"><i class="bi bi-speedometer2 me-2"></i>Dashboard</a></li>
      <li><a href="/admin/blogs" class="nav-link active"><i class="bi bi-pencil-square me-2"></i>Blogs</a></li>
      <li><a href="/admin/blogs/new" class="nav-link"><i class="bi bi-plus-circle me-2"></i>New Post</a></li>
      <hr class="border-secondary my-2">
      <li><a href="/" class="nav-link" target="_blank"><i class="bi bi-box-arrow-up-right me-2"></i>View Site</a></li>
    </ul>
    <form action="/admin/logout" method="POST" class="mt-auto">
      <button class="btn btn-outline-danger btn-sm w-100"><i class="bi bi-box-arrow-left me-1"></i>Logout</button>
    </form>
  </nav>

  <div class="main-content p-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
      <h4 class="fw-bold mb-0"><i class="bi bi-pencil-square me-2"></i>Manage Blogs</h4>
      <a href="/admin/blogs/new" class="btn btn-warning fw-bold">
        <i class="bi bi-plus-lg me-1"></i>New Post
      </a>
    </div>

    <% const qs = typeof query !== 'undefined' ? query : {}; %>
    <% if (qs.msg) { %><div class="alert alert-success"><%= qs.msg %></div><% } %>

    <div class="card border-0 shadow-sm">
      <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
          <thead class="table-light">
            <tr>
              <th>Title</th><th>Category</th><th>Status</th><th>Views</th><th>Date</th><th>Actions</th>
            </tr>
          </thead>
          <tbody>
            <% if (blogs.length) { %>
            <% blogs.forEach(b => { %>
            <tr>
              <td class="small fw-semibold"><%= b.title.substring(0, 60) %>...</td>
              <td><span class="badge bg-primary"><%= b.category %></span></td>
              <td>
                <% if (b.published) { %>
                <span class="badge bg-success">Published</span>
                <% } else { %>
                <span class="badge bg-secondary">Draft</span>
                <% } %>
              </td>
              <td><%= b.views %></td>
              <td class="small text-muted"><%= new Date(b.createdAt).toLocaleDateString() %></td>
              <td>
                <a href="/admin/blogs/<%= b._id %>/edit" class="btn btn-sm btn-outline-primary me-1">
                  <i class="bi bi-pencil"></i>
                </a>
                <form action="/admin/blogs/<%= b._id %>?_method=DELETE" method="POST" class="d-inline"
                      onsubmit="return confirm('Delete this blog post?')">
                  <input type="hidden" name="_method" value="DELETE">
                  <button class="btn btn-sm btn-outline-danger"><i class="bi bi-trash"></i></button>
                </form>
              </td>
            </tr>
            <% }) %>
            <% } else { %>
            <tr><td colspan="6" class="text-center text-muted py-4">No blog posts yet. <a href="/admin/blogs/new">Create one!</a></td></tr>
            <% } %>
          </tbody>
        </table>
      </div>
    </div>
  </div>
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
