<!-- ════ SIDEBAR ═════════════════════════════════════════════════════════════ -->
<aside>

  <!-- Categories -->
  <div class="sidebar-widget">
    <div class="sidebar-widget-header navy">
      <i class="bi bi-grid-fill"></i> Browse Categories
    </div>
    <div class="list-group list-group-flush">
      <% categories.forEach(cat => { %>
      <a href="/news/<%= cat.slug %>"
         class="list-group-item list-group-item-action d-flex justify-content-between align-items-center py-2">
        <span style="font-size:.85rem;"><%= cat.icon %> <%= cat.label %></span>
        <i class="bi bi-chevron-right" style="font-size:.7rem;color:var(--primary);"></i>
      </a>
      <% }) %>
    </div>
  </div>

  <!-- Sidebar Ad -->
  <%- include('./ad-banner', { id: 'ad-sidebar-1', label: 'Advertisement', size: '300x250' }) %>

  <!-- Trending -->
  <% if (typeof trending !== 'undefined' && trending.length) { %>
  <div class="sidebar-widget">
    <div class="sidebar-widget-header red">
      <i class="bi bi-fire"></i> Trending Now
    </div>
    <div class="list-group list-group-flush">
      <% trending.forEach((art, i) => { %>
      <a href="/news/<%= art.category %>/<%= art.slug %>"
         class="list-group-item list-group-item-action py-2">
        <div class="d-flex gap-2 align-items-start">
          <span class="trend-num mt-1"><%= i + 1 %></span>
          <span style="font-size:.8rem;font-weight:600;line-height:1.4;"><%= art.title.substring(0, 72) %>…</span>
        </div>
      </a>
      <% }) %>
    </div>
  </div>
  <% } %>

  <!-- Latest Blog Posts -->
  <% if (typeof latestBlogs !== 'undefined' && latestBlogs.length) { %>
  <div class="sidebar-widget">
    <div class="sidebar-widget-header teal">
      <i class="bi bi-pencil-square"></i> Latest from Blog
    </div>
    <div class="list-group list-group-flush">
      <% latestBlogs.forEach(b => { %>
      <a href="/blog/<%= b.slug %>" class="list-group-item list-group-item-action py-2">
        <div style="font-size:.82rem;font-weight:600;line-height:1.4;"><%= b.title.substring(0, 62) %>…</div>
        <div class="mt-1" style="font-size:.72rem;color:var(--text-light);"><i class="bi bi-calendar3 me-1"></i><%= new Date(b.createdAt).toLocaleDateString('en-IN',{day:'numeric',month:'short',year:'numeric'}) %></div>
      </a>
      <% }) %>
    </div>
  </div>
  <% } %>

  <!-- Newsletter CTA -->
  <div class="sidebar-widget p-3" style="background:var(--gradient);">
    <h6 class="text-white fw-bold mb-1"><i class="bi bi-bell me-1"></i>Stay Updated!</h6>
    <p style="font-size:.78rem;color:rgba(255,255,255,.85);margin-bottom:12px;">Get the latest news delivered to your feed. Updating every 10 minutes.</p>
    <a href="/" class="btn btn-sm btn-light fw-bold w-100" style="border-radius:50px;">Browse All News</a>
  </div>

</aside>
