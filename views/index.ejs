<%- include('partials/header') %>

<div class="row g-4">
  <!-- ── Main Content ─────────────────────────────────────────────── -->
  <div class="col-lg-9">

    <!-- Hero Carousel -->
    <% if (heroArticles && heroArticles.length) { %>
    <div id="heroCarousel" class="carousel slide mb-4 rounded overflow-hidden shadow" data-bs-ride="carousel">
      <div class="carousel-indicators">
        <% heroArticles.forEach((_, i) => { %>
        <button type="button" data-bs-target="#heroCarousel" data-bs-slide-to="<%= i %>"
                class="<%= i === 0 ? 'active' : '' %>"></button>
        <% }) %>
      </div>
      <div class="carousel-inner">
        <% heroArticles.forEach((art, i) => { %>
        <div class="carousel-item <%= i === 0 ? 'active' : '' %>">
          <img src="<%= art.urlToImage || '/images/placeholder.jpg' %>"
               class="d-block w-100" alt="<%= art.title %>"
               style="height:420px; object-fit:cover;"
               onerror="this.src='/images/placeholder.jpg'">
          <div class="carousel-caption text-start" style="background:rgba(0,0,0,.55); border-radius:8px; padding:12px 16px; bottom:20px; max-width:70%;">
            <span class="badge bg-warning text-dark mb-1"><%= art.category %></span>
            <h5 class="fw-bold mb-1">
              <a href="/news/<%= art.category %>/<%= art.slug %>" class="text-white text-decoration-none">
                <%= art.title.substring(0, 90) %>...
              </a>
            </h5>
            <small><i class="bi bi-clock me-1"></i><%= new Date(art.publishedAt).toDateString() %></small>
          </div>
        </div>
        <% }) %>
      </div>
      <button class="carousel-control-prev" type="button" data-bs-target="#heroCarousel" data-bs-slide="prev">
        <span class="carousel-control-prev-icon"></span>
      </button>
      <button class="carousel-control-next" type="button" data-bs-target="#heroCarousel" data-bs-slide="next">
        <span class="carousel-control-next-icon"></span>
      </button>
    </div>
    <% } %>

    <!-- Top Ad -->
    <%- include('partials/ad-banner', { id: 'home-ad-1', label: 'Advertisement' }) %>

    <!-- Category Sections -->
    <% categories.forEach(cat => { %>
    <% if (categoryNews[cat.slug] && categoryNews[cat.slug].length) { %>
    <section class="mb-5">
      <div class="d-flex justify-content-between align-items-center mb-3">
        <h4 class="fw-bold category-heading">
          <span class="border-start border-warning border-4 ps-2">
            <%= cat.icon %> <%= cat.label %>
          </span>
        </h4>
        <a href="/news/<%= cat.slug %>" class="btn btn-sm btn-outline-warning">
          View All <i class="bi bi-arrow-right ms-1"></i>
        </a>
      </div>
      <div class="row g-3">
        <% categoryNews[cat.slug].forEach(article => { %>
        <div class="col-sm-6 col-md-4">
          <%- include('partials/article-card', { article }) %>
        </div>
        <% }) %>
      </div>
    </section>
    <!-- Mid Ad every 2 categories -->
    <% } %>
    <% }) %>

    <!-- Latest Blog Posts -->
    <% if (latestBlogs && latestBlogs.length) { %>
    <section class="mb-5">
      <div class="d-flex justify-content-between align-items-center mb-3">
        <h4 class="fw-bold">
          <span class="border-start border-primary border-4 ps-2">
            <i class="bi bi-pencil-square"></i> Latest Blog Posts
          </span>
        </h4>
        <a href="/blog" class="btn btn-sm btn-outline-primary">View All <i class="bi bi-arrow-right ms-1"></i></a>
      </div>
      <div class="row g-3">
        <% latestBlogs.forEach(blog => { %>
        <div class="col-md-4">
          <div class="card h-100 border-0 shadow-sm article-card">
            <% if (blog.coverImage) { %>
            <img src="<%= blog.coverImage %>" class="card-img-top" alt="<%= blog.title %>"
                 style="height:180px; object-fit:cover;">
            <% } %>
            <div class="card-body d-flex flex-column">
              <span class="badge bg-primary mb-2 align-self-start">Blog</span>
              <h6 class="card-title fw-bold">
                <a href="/blog/<%= blog.slug %>" class="text-decoration-none text-dark stretched-link">
                  <%= blog.title %>
                </a>
              </h6>
              <p class="small text-muted flex-grow-1"><%= blog.excerpt ? blog.excerpt.substring(0, 100) + '...' : '' %></p>
              <small class="text-muted mt-auto"><i class="bi bi-person me-1"></i><%= blog.author %></small>
            </div>
          </div>
        </div>
        <% }) %>
      </div>
    </section>
    <% } %>

  </div>

  <!-- ── Sidebar ──────────────────────────────────────────────────── -->
  <div class="col-lg-3">
    <%- include('partials/sidebar', { trending, latestBlogs }) %>
  </div>
</div>

<%- include('partials/footer') %>
