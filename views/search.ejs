<%- include('partials/header') %>

<div class="row g-4">
  <div class="col-lg-9">
    <h2 class="fw-bold mb-1">
      <i class="bi bi-search me-2"></i>Search Results
    </h2>
    <p class="text-muted mb-4">
      <% if (q) { %>Showing results for <strong>"<%= q %>"</strong><% } else { %>Enter a keyword above<% } %>
    </p>

    <% if (articles.length) { %>
    <div class="row g-3">
      <% articles.forEach(article => { %>
      <div class="col-sm-6 col-md-4">
        <%- include('partials/article-card', { article }) %>
      </div>
      <% }) %>
    </div>

    <% if (totalPages > 1) { %>
    <nav class="mt-4">
      <ul class="pagination justify-content-center">
        <% for (let i = 1; i <= totalPages; i++) { %>
        <li class="page-item <%= i === page ? 'active' : '' %>">
          <a class="page-link" href="/search?q=<%= encodeURIComponent(q) %>&page=<%= i %>"><%= i %></a>
        </li>
        <% } %>
      </ul>
    </nav>
    <% } %>
    <% } else if (q) { %>
    <div class="alert alert-warning">No results found for "<%= q %>".</div>
    <% } %>
  </div>

  <div class="col-lg-3">
    <%- include('partials/sidebar', { trending: [], latestBlogs: [] }) %>
  </div>
</div>

<%- include('partials/footer') %>
