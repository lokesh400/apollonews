<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title><%= title %> | <%= siteName %></title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">
  <link rel="icon" type="image/png" href="/images/logo.png">
  <style>
    body { background: #f4f6f8; }
    .sidebar-admin { width: 220px; min-height: 100vh; position: fixed; top: 0; left: 0; background: #1e2a38; z-index: 100; }
    .main-content  { margin-left: 220px; }
    .sidebar-admin .nav-link { color: #adb5bd; }
    .sidebar-admin .nav-link:hover, .sidebar-admin .nav-link.active { color: #fff; background: rgba(255,193,7,.15); border-radius: 6px; }
  </style>
</head>
<body>
  <!-- Sidebar -->
  <nav class="sidebar-admin p-3 d-flex flex-column">
    <div class="mb-4 mt-2 text-center">
      <img src="/images/logo.png" alt="<%= siteName %>" style="height:40px;width:auto;object-fit:contain;filter:brightness(0) invert(1);">
    </div>
    <ul class="nav flex-column gap-1 flex-grow-1">
      <li class="nav-item"><a href="/admin" class="nav-link <%= currentPath === '/admin' ? 'active' : '' %>"><i class="bi bi-speedometer2 me-2"></i>Dashboard</a></li>
      <li class="nav-item"><a href="/admin/blogs" class="nav-link <%= currentPath.includes('/admin/blogs') ? 'active' : '' %>"><i class="bi bi-pencil-square me-2"></i>Blogs</a></li>
      <li class="nav-item"><a href="/admin/blogs/new" class="nav-link"><i class="bi bi-plus-circle me-2"></i>New Blog Post</a></li>
      <hr class="border-secondary my-2">
      <li class="nav-item">
        <form action="/admin/fetch-news" method="POST">
          <button class="nav-link w-100 text-start border-0 bg-transparent text-warning">
            <i class="bi bi-arrow-clockwise me-2"></i>Fetch News Now
          </button>
        </form>
      </li>
      <li class="nav-item">
        <form action="/admin/clean-news" method="POST">
          <button class="nav-link w-100 text-start border-0 bg-transparent text-danger">
            <i class="bi bi-trash me-2"></i>Clean Old News
          </button>
        </form>
      </li>
      <hr class="border-secondary my-2">
      <li class="nav-item"><a href="/" class="nav-link" target="_blank"><i class="bi bi-box-arrow-up-right me-2"></i>View Site</a></li>
    </ul>
    <form action="/admin/logout" method="POST" class="mt-auto">
      <button class="btn btn-outline-danger btn-sm w-100"><i class="bi bi-box-arrow-left me-1"></i>Logout</button>
    </form>
  </nav>

  <!-- Main Content -->
  <div class="main-content p-4">
    <h4 class="fw-bold mb-1"><i class="bi bi-speedometer2 me-2"></i>Dashboard</h4>
    <p class="text-muted mb-4">Welcome back, Admin!</p>

    <% const msg   = typeof query !== 'undefined' && query ? query.msg   : null; %>
    <% const error = typeof query !== 'undefined' && query ? query.error : null; %>

    <!-- Stats Cards -->
    <div class="row g-3 mb-4">
      <div class="col-md-3">
        <div class="card border-0 shadow-sm text-center p-3">
          <div class="display-6 fw-bold text-warning"><%= articleCount %></div>
          <small class="text-muted">News Articles</small>
        </div>
      </div>
      <div class="col-md-3">
        <div class="card border-0 shadow-sm text-center p-3">
          <div class="display-6 fw-bold text-primary"><%= blogCount %></div>
          <small class="text-muted">Blog Posts</small>
        </div>
      </div>
      <div class="col-md-3">
        <div class="card border-0 shadow-sm text-center p-3">
          <div class="display-6 fw-bold text-success"><%= categories.length %></div>
          <small class="text-muted">Categories</small>
        </div>
      </div>
      <div class="col-md-3">
        <div class="card border-0 shadow-sm text-center p-3">
          <div class="display-6 fw-bold text-info">10m</div>
          <small class="text-muted">Fetch Interval</small>
        </div>
      </div>
    </div>

    <div class="row g-4">
      <!-- Latest Articles -->
      <div class="col-md-8">
        <div class="card border-0 shadow-sm">
          <div class="card-header bg-white fw-bold border-0">
            <i class="bi bi-newspaper me-1 text-warning"></i> Latest Articles
          </div>
          <div class="table-responsive">
            <table class="table table-hover mb-0 small">
              <thead class="table-light">
                <tr><th>Title</th><th>Category</th><th>Date</th><th>Views</th></tr>
              </thead>
              <tbody>
                <% latestArticles.forEach(a => { %>
                <tr>
                  <td><a href="/news/<%= a.category %>/<%= a.slug %>" target="_blank" class="text-decoration-none">
                    <%= a.title.substring(0, 60) %>...
                  </a></td>
                  <td><span class="badge bg-warning text-dark"><%= a.category %></span></td>
                  <td><%= new Date(a.publishedAt).toLocaleDateString() %></td>
                  <td><%= a.views %></td>
                </tr>
                <% }) %>
              </tbody>
            </table>
          </div>
        </div>
      </div>

      <!-- Latest Blogs -->
      <div class="col-md-4">
        <div class="card border-0 shadow-sm">
          <div class="card-header bg-white fw-bold border-0">
            <i class="bi bi-pencil-square me-1 text-primary"></i> Blog Posts
          </div>
          <div class="list-group list-group-flush">
            <% latestBlogs.forEach(b => { %>
            <a href="/admin/blogs/<%= b._id %>/edit" class="list-group-item list-group-item-action small py-2">
              <div class="fw-semibold"><%= b.title.substring(0, 50) %>...</div>
              <div class="text-muted" style="font-size:11px;">
                <%= new Date(b.createdAt).toLocaleDateString() %>
                <% if (!b.published) { %><span class="badge bg-secondary ms-1">Draft</span><% } %>
              </div>
            </a>
            <% }) %>
            <a href="/admin/blogs" class="list-group-item list-group-item-action text-center text-primary small">
              View all blogs <i class="bi bi-arrow-right ms-1"></i>
            </a>
          </div>
        </div>
      </div>
    </div>

  </div><!-- /main-content -->
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
