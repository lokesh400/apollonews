<%- include('partials/header') %>

<div class="row g-4">
  <div class="col-lg-9">
    <!-- Category Header -->
    <div class="d-flex align-items-center gap-3 mb-4 pb-2 border-bottom">
      <span style="font-size:2.5rem;"><%= catInfo.icon %></span>
      <div>
        <h2 class="fw-bold mb-0"><%= catInfo.label %></h2>
        <small class="text-muted"><%= articles.length %> articles on page <%= page %></small>
      </div>
    </div>

    <!-- Articles grid -->
    <% if (articles.length) { %>
    <div class="row g-3">
      <% articles.forEach((article, idx) => { %>
      <div class="col-sm-6 col-md-4">
        <%- include('partials/article-card', { article }) %>
      </div>
      <% if ((idx + 1) % 6 === 0) { %>
      </div>
      <%- include('partials/ad-banner', { id: 'ad-cat-' + (idx + 1), label: 'Advertisement', size: '728x90' }) %>
      <div class="row g-3">
      <% } %>
      <% }) %>
    </div>

    <!-- Pagination -->
    <% if (totalPages > 1) { %>
    <nav class="mt-4">
      <ul class="pagination justify-content-center">
        <% for (let i = 1; i <= totalPages; i++) { %>
        <li class="page-item <%= i === page ? 'active' : '' %>">
          <a class="page-link" href="/news/<%= catInfo.slug %>?page=<%= i %>"><%= i %></a>
        </li>
        <% } %>
      </ul>
    </nav>
    <% } %>

    <% } else { %>
    <div class="alert alert-info mt-3">
      <i class="bi bi-info-circle me-2"></i>
      No articles yet for <strong><%= catInfo.label %></strong>.
      They'll appear after the next automatic fetch (every 10 minutes).
    </div>
    <% } %>
  </div>

  <div class="col-lg-3">
    <%- include('partials/sidebar', { trending: [], latestBlogs: [] }) %>
  </div>
</div>

<%- include('partials/footer') %>
