<%- include('../partials/header') %>

<div class="row g-4">
  <div class="col-lg-8 mx-auto">
    <nav aria-label="breadcrumb" class="mb-3">
      <ol class="breadcrumb"><li class="breadcrumb-item"><a href="/">Home</a></li><li class="breadcrumb-item active">Contact Us</li></ol>
    </nav>

    <div class="card border-0 shadow-sm p-4 p-md-5">
      <div class="d-flex align-items-center gap-3 mb-4">
        <span style="background:var(--gradient);width:48px;height:48px;border-radius:12px;display:flex;align-items:center;justify-content:center;flex-shrink:0;">
          <i class="bi bi-envelope-fill text-white fs-5"></i>
        </span>
        <div>
          <h1 class="h3 fw-bold mb-0">Contact Us</h1>
          <p class="text-muted small mb-0">We read every message and aim to respond within 2 working days</p>
        </div>
      </div>

      <% if (success) { %>
      <div class="alert alert-success d-flex align-items-center gap-2 mb-4">
        <i class="bi bi-check-circle-fill fs-5"></i>
        <div>
          <strong>Message sent!</strong> Thank you for reaching out. We'll get back to you within 2 working days.
        </div>
      </div>
      <% } %>

      <% if (error) { %>
      <div class="alert alert-danger d-flex align-items-center gap-2 mb-4">
        <i class="bi bi-exclamation-triangle-fill fs-5"></i>
        <div><%= error %></div>
      </div>
      <% } %>

      <% if (!success) { %>
      <form method="POST" action="/contact" novalidate>
        <div class="row g-3">
          <div class="col-md-6">
            <label class="form-label fw-semibold">Your Name <span class="text-danger">*</span></label>
            <input type="text" name="name" class="form-control" placeholder="e.g. Rahul Sharma" required>
          </div>
          <div class="col-md-6">
            <label class="form-label fw-semibold">Email Address <span class="text-danger">*</span></label>
            <input type="email" name="email" class="form-control" placeholder="you@example.com" required>
          </div>
          <div class="col-12">
            <label class="form-label fw-semibold">Subject <span class="text-danger">*</span></label>
            <select name="subject" class="form-select" required>
              <option value="" disabled selected>Select a subject</option>
              <option>General Enquiry</option>
              <option>News Tip / Story Suggestion</option>
              <option>Correction Request</option>
              <option>DMCA / Copyright Complaint</option>
              <option>Advertising &amp; Partnerships</option>
              <option>Technical Issue</option>
              <option>Other</option>
            </select>
          </div>
          <div class="col-12">
            <label class="form-label fw-semibold">Message <span class="text-danger">*</span></label>
            <textarea name="message" class="form-control" rows="6" placeholder="Please describe your enquiry in detail…" required></textarea>
          </div>
          <div class="col-12">
            <p class="text-muted small mb-3">
              By submitting this form you agree to our <a href="/privacy-policy">Privacy Policy</a>.
              We do not share your contact information with third parties.
            </p>
            <button type="submit" class="btn btn-primary px-5 fw-bold">
              <i class="bi bi-send-fill me-2"></i>Send Message
            </button>
          </div>
        </div>
      </form>
      <% } %>

      <hr class="my-4">

      <div class="row g-3">
        <div class="col-md-4 text-center">
          <i class="bi bi-envelope-open fs-2 mb-2" style="color:var(--primary);"></i>
          <h6 class="fw-bold">Editorial</h6>
          <p class="small text-muted">News tips, corrections, editorial feedback</p>
        </div>
        <div class="col-md-4 text-center">
          <i class="bi bi-bullseye fs-2 mb-2" style="color:var(--primary);"></i>
          <h6 class="fw-bold">Advertising</h6>
          <p class="small text-muted">Sponsored content and display advertising</p>
        </div>
        <div class="col-md-4 text-center">
          <i class="bi bi-shield-check fs-2 mb-2" style="color:var(--primary);"></i>
          <h6 class="fw-bold">Legal / DMCA</h6>
          <p class="small text-muted">Copyright complaints and legal notices</p>
        </div>
      </div>
    </div>
  </div>
</div>

<%- include('../partials/footer') %>
