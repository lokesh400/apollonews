<!-- ════ ARTICLE CARD ════════════════════════════════════════════════════════ -->
<div class="article-card h-100">
  <div class="article-img-wrap" style="height:185px;overflow:hidden;">
    <% if (article.urlToImage) { %>
    <img src="<%= article.urlToImage %>" alt="<%= article.title %>"
         style="width:100%;height:185px;object-fit:cover;"
         onerror="this.parentElement.innerHTML='<div style=height:185px;background:linear-gradient(135deg,#1d3557,#0d1b2a);display:flex;align-items:center;justify-content:center;><i class=\'bi bi-newspaper\' style=\'color:rgba(255,255,255,.3);font-size:3rem;\'></i></div>'">
    <% } else { %>
    <div style="height:185px;background:var(--gradient-hero);display:flex;align-items:center;justify-content:center;">
      <i class="bi bi-newspaper" style="color:rgba(255,255,255,.3);font-size:3rem;"></i>
    </div>
    <% } %>
  </div>
  <div class="p-3 d-flex flex-column" style="flex:1;">
    <div class="d-flex align-items-center gap-2 mb-2">
      <span class="cat-badge"><%= article.category %></span>
      <span class="source-chip"><i class="bi bi-globe me-1"></i><%= article.source ? article.source.substring(0,18) : 'News' %></span>
    </div>
    <h6 class="fw-bold lh-sm mb-2" style="font-size:.88rem;">
      <a href="/news/<%= article.category %>/<%= article.slug %>"
         class="article-title stretched-link">
        <%= article.title.length > 85 ? article.title.substring(0, 85) + '…' : article.title %>
      </a>
    </h6>
    <p class="mb-0 mt-auto pt-2" style="font-size:.76rem;color:var(--text-light);border-top:1px solid var(--border);display:flex;justify-content:space-between;">
      <span><i class="bi bi-clock me-1"></i><%= new Date(article.publishedAt).toLocaleDateString('en-IN',{day:'numeric',month:'short'}) %></span>
      <span><i class="bi bi-eye me-1"></i><%= article.views %></span>
    </p>
  </div>
</div>
