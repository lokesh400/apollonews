<%- include('../partials/header') %>

<div class="row g-4">
  <div class="col-lg-9">
    <nav aria-label="breadcrumb" class="mb-3">
      <ol class="breadcrumb">
        <li class="breadcrumb-item"><a href="/">Home</a></li>
        <li class="breadcrumb-item"><a href="/blog">Blog</a></li>
        <li class="breadcrumb-item active"><%= blog.title.substring(0, 40) %>...</li>
      </ol>
    </nav>

    <article>
      <span class="badge bg-primary mb-2"><%= blog.category %></span>
      <h1 class="fw-bold lh-sm mb-3"><%= blog.title %></h1>

      <div class="d-flex flex-wrap gap-3 text-muted small mb-3 pb-3 border-bottom">
        <span><i class="bi bi-person me-1"></i><%= blog.author %></span>
        <span><i class="bi bi-calendar me-1"></i><%= new Date(blog.createdAt).toDateString() %></span>
        <span><i class="bi bi-eye me-1"></i><%= blog.views %> views</span>
        <% if (blog.tags && blog.tags.length) { %>
        <span>
          <i class="bi bi-tags me-1"></i>
          <% blog.tags.forEach(tag => { %>
          <span class="badge bg-light text-dark border"><%= tag %></span>
          <% }) %>
        </span>
        <% } %>
      </div>

      <% if (blog.coverImage) { %>
      <img src="<%= blog.coverImage %>" alt="<%= blog.title %>"
           class="img-fluid rounded shadow-sm mb-4 w-100"
           style="max-height:450px; object-fit:cover;">
      <% } %>

      <div class="blog-content fs-6 lh-lg">
        <%- blog.content %>
      </div>

      <!-- Share -->
      <div class="d-flex gap-2 mt-4 mb-5 flex-wrap">
        <span class="fw-semibold align-self-center">Share:</span>
        <a href="https://twitter.com/intent/tweet?url=<%= encodeURIComponent(siteUrl + '/blog/' + blog.slug) %>&text=<%= encodeURIComponent(blog.title) %>"
           target="_blank" class="btn btn-sm btn-outline-dark">
          <i class="bi bi-twitter-x me-1"></i>Twitter
        </a>
        <a href="https://www.facebook.com/sharer/sharer.php?u=<%= encodeURIComponent(siteUrl + '/blog/' + blog.slug) %>"
           target="_blank" class="btn btn-sm btn-outline-primary">
          <i class="bi bi-facebook me-1"></i>Facebook
        </a>
        <a href="https://api.whatsapp.com/send?text=<%= encodeURIComponent(blog.title + ' ' + siteUrl + '/blog/' + blog.slug) %>"
           target="_blank" class="btn btn-sm btn-outline-success">
          <i class="bi bi-whatsapp me-1"></i>WhatsApp
        </a>
      </div>
    </article>

    <!-- In-Post Ad -->
    <%- include('../partials/ad-banner', { id: 'ad-blog-mid', label: 'Advertisement', size: '728x90' }) %>

    <!-- Related Blogs -->
    <% if (related && related.length) { %>
    <h5 class="fw-bold border-start border-primary border-4 ps-2 mb-3">More from Blog</h5>
    <div class="row g-3">
      <% related.forEach(b => { %>
      <div class="col-md-4">
        <div class="card h-100 border-0 shadow-sm article-card">
          <% if (b.coverImage) { %>
          <img src="<%= b.coverImage %>" class="card-img-top" style="height:140px; object-fit:cover;" alt="">
          <% } %>
          <div class="card-body">
            <h6 class="fw-bold">
              <a href="/blog/<%= b.slug %>" class="text-decoration-none text-dark stretched-link">
                <%= b.title.substring(0, 60) %>...
              </a>
            </h6>
            <small class="text-muted"><%= new Date(b.createdAt).toDateString() %></small>
          </div>
        </div>
      </div>
      <% }) %>
    </div>
    <% } %>
  </div>

  <div class="col-lg-3">
    <%- include('../partials/sidebar', { trending: [], latestBlogs: [] }) %>
  </div>
</div>

<%- include('../partials/footer') %>
