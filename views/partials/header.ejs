<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %> | <%= siteName %></title>
  <meta name="description" content="<%= typeof article !== 'undefined' ? article.description : siteDesc %>">
  <meta property="og:title" content="<%= title %> | <%= siteName %>">
  <meta property="og:type" content="website">
  <meta name="admolo-verification" content="DTP5Q39YZTGG7RMX71WKUAEYPJYQSATS">

  <!-- Bootstrap 5 -->
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
  <!-- Bootstrap Icons -->
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">
  <!-- Custom CSS -->
  <link href="/css/style.css" rel="stylesheet">

  <!--
    ═══════════════════════════════════════════════════════
    GOOGLE ADSENSE — Replace with your publisher ID
    Uncomment the lines below once you have your AdSense account approved.
    ═══════════════════════════════════════════════════════
    <script async src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-XXXXXXXXXXXXXXXXX"
         crossorigin="anonymous"></script>
  -->
</head>
<body>

<!-- ══ Top Ad Banner ══════════════════════════════════════════════════════════ -->
<%- include('ad-banner', { id: 'top-banner', label: 'Advertisement' }) %>

<!-- ══ Navbar ════════════════════════════════════════════════════════════════ -->
<nav class="navbar navbar-expand-lg navbar-dark bg-dark sticky-top shadow">
  <div class="container">
    <a class="navbar-brand fw-bold fs-4" href="/">
      <i class="bi bi-newspaper text-warning me-1"></i><%= siteName %>
    </a>
    <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navMenu">
      <span class="navbar-toggler-icon"></span>
    </button>
    <div class="collapse navbar-collapse" id="navMenu">
      <ul class="navbar-nav me-auto mb-2 mb-lg-0">
        <li class="nav-item"><a class="nav-link <%= currentPath === '/' ? 'active' : '' %>" href="/">Home</a></li>
        <% categories.forEach(cat => { %>
        <li class="nav-item">
          <a class="nav-link <%= currentPath.includes('/news/' + cat.slug) ? 'active' : '' %>" href="/news/<%= cat.slug %>">
            <%= cat.icon %> <%= cat.label %>
          </a>
        </li>
        <% }) %>
        <li class="nav-item"><a class="nav-link <%= currentPath.startsWith('/blog') ? 'active' : '' %>" href="/blog">Blog</a></li>
      </ul>
      <!-- Search -->
      <form class="d-flex" action="/search" method="GET">
        <input class="form-control me-2" type="search" name="q" placeholder="Search news..." aria-label="Search"
               value="<%= typeof q !== 'undefined' ? q : '' %>">
        <button class="btn btn-outline-warning" type="submit"><i class="bi bi-search"></i></button>
      </form>
    </div>
  </div>
</nav>

<!-- ══ Breaking News Ticker ═══════════════════════════════════════════════════ -->
<div class="bg-danger text-white py-1 overflow-hidden">
  <div class="container d-flex align-items-center gap-3">
    <span class="badge bg-white text-danger fw-bold text-uppercase flex-shrink-0">Breaking</span>
    <div id="tickerWrap" class="ticker-wrap flex-grow-1 overflow-hidden">
      <div class="ticker" id="ticker">
        <!-- Filled via JS from /search?q= -->
        Loading headlines&hellip;
      </div>
    </div>
  </div>
</div>

<div class="container-fluid px-0 py-3">
  <div class="container">
