<%- include('../partials/header') %>

<div class="row g-4">
  <div class="col-lg-9">
    <h2 class="fw-bold mb-4 border-start border-primary border-4 ps-2">
      <i class="bi bi-pencil-square me-1"></i> Blog
    </h2>

    <% if (blogs.length) { %>
    <div class="row g-4">
      <% blogs.forEach((blog, idx) => { %>
      <div class="col-md-6">
        <div class="card h-100 border-0 shadow-sm article-card">
          <% if (blog.coverImage) { %>
          <img src="<%= blog.coverImage %>" class="card-img-top" alt="<%= blog.title %>"
               style="height:200px; object-fit:cover;">
          <% } %>
          <div class="card-body d-flex flex-column">
            <span class="badge bg-primary mb-2 align-self-start"><%= blog.category %></span>
            <h5 class="card-title fw-bold">
              <a href="/blog/<%= blog.slug %>" class="text-decoration-none text-dark stretched-link">
                <%= blog.title %>
              </a>
            </h5>
            <p class="text-muted small flex-grow-1">
              <%= blog.excerpt ? blog.excerpt.substring(0, 130) + '...' : '' %>
            </p>
            <div class="d-flex justify-content-between align-items-center mt-auto pt-2 border-top small text-muted">
              <span><i class="bi bi-person me-1"></i><%= blog.author %></span>
              <span><i class="bi bi-calendar me-1"></i><%= new Date(blog.createdAt).toDateString() %></span>
            </div>
          </div>
        </div>
      </div>


      <% }) %>
    </div>

    <% if (totalPages > 1) { %>
    <nav class="mt-4">
      <ul class="pagination justify-content-center">
        <% for (let i = 1; i <= totalPages; i++) { %>
        <li class="page-item <%= i === page ? 'active' : '' %>">
          <a class="page-link" href="/blog?page=<%= i %>"><%= i %></a>
        </li>
        <% } %>
      </ul>
    </nav>
    <% } %>
    <% } else { %>
    <div class="alert alert-info">No blog posts yet. Check back soon!</div>
    <% } %>
  </div>

  <div class="col-lg-3">
    <%- include('../partials/sidebar', { trending: [], latestBlogs: [] }) %>
  </div>
</div>

<%- include('../partials/footer') %>
