<!-- ════ ARTICLE CARD ════════════════════════════════════════════════════════ -->
<div class="card h-100 border-0 shadow-sm article-card">
  <% if (article.urlToImage) { %>
  <img src="<%= article.urlToImage %>" class="card-img-top" alt="<%= article.title %>"
       style="height:180px; object-fit:cover;"
       onerror="this.src='/images/placeholder.jpg'">
  <% } else { %>
  <div class="card-img-top bg-secondary d-flex align-items-center justify-content-center"
       style="height:180px;">
    <i class="bi bi-newspaper text-white" style="font-size:3rem;"></i>
  </div>
  <% } %>
  <div class="card-body d-flex flex-column">
    <span class="badge bg-warning text-dark mb-2 align-self-start text-uppercase" style="font-size:10px;">
      <%= article.category %>
    </span>
    <h6 class="card-title fw-bold lh-sm">
      <a href="/news/<%= article.category %>/<%= article.slug %>"
         class="text-decoration-none text-dark stretched-link article-title">
        <%= article.title.length > 80 ? article.title.substring(0, 80) + '...' : article.title %>
      </a>
    </h6>
    <p class="card-text text-muted small flex-grow-1">
      <%= article.description ? (article.description.length > 100 ? article.description.substring(0, 100) + '...' : article.description) : '' %>
    </p>
    <div class="d-flex justify-content-between align-items-center mt-auto pt-2 border-top">
      <small class="text-muted"><i class="bi bi-clock me-1"></i><%= new Date(article.publishedAt).toDateString() %></small>
      <small class="text-muted"><i class="bi bi-eye me-1"></i><%= article.views %></small>
    </div>
  </div>
</div>
